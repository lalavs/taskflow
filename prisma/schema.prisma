generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id      String @id @default(uuid())
  x       Float
  y       Float
  content String
  height  Float @default(96)

  @@map("notes")
}

model BoardView {
  id    String @id @default("default")
  x     Float  @default(0)
  y     Float  @default(0)
  zoom  Float  @default(1)

  @@map("board_views")
}
